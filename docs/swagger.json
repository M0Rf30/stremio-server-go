        "/{infoHash}/{fileIdx}": {
            "get": {
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "Streaming"
                ],
                "summary": "Stream a torrent file by info hash and file index",
                "parameters": [
                    {
                        "type": "string",
                        "description": "40-hex info hash",
                        "name": "infoHash",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "file index",
                        "name": "fileIdx",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "byte range",
                        "name": "Range",
                        "in": "header"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "206": {
                        "description": "partial content",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "416": {
                        "description": "Requested Range Not Satisfiable"
                    }
                }
            }
        },
